choices = [e for e in currentEnemies if e.alive]
if len(choices):
    target = choice(choices)
    t.alert(f"[{self.name.upper()}] you yearn to become like {target.name}")
    target.applyEffect(effects["constriction"], 1, 3, infinite=False)
    t.alert(f"{target.name} gained 1 Constriction!", clear=False)